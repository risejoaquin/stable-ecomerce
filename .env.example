# --- REQUIRED ---
VITE_API_URL=http://localhost:3000
# Supabase configuration for Database & Storage
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- AUTHENTICATION (Clerk) ---
# For frontend components
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# For backend validation
CLERK_SECRET_KEY=sk_test_...

# --- PAYMENTS (Stripe) ---
# For backend to create checkout sessions
STRIPE_SECRET_KEY=sk_test_...
# For validating webhook events
STRIPE_WEBHOOK_SECRET=whsec_...
# For frontend to initialize Stripe elements (if needed)
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# --- EMAILS (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=Store <onboarding@resend.dev>
ADMIN_EMAIL=admin@example.com

# --- OPTIONAL ---
# Connection string for backup script
SUPABASE_DB_URL=postgresql://...
